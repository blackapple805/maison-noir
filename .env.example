# Environment variables required by the Concierge API endpoint.
# Copy these into Vercel project settings (Settings → Environment Variables).
# Never commit the real .env.local file — it's gitignored.

# --- Resend (transactional email) ---
# Get this from https://resend.com → API Keys → Create
RESEND_API_KEY=re_your_key_here

# The inbox where Concierge messages will be delivered.
CONCIERGE_TO_EMAIL=you@example.com

# The sender identity. Use 'onboarding@resend.dev' until you've verified
# a domain in Resend; afterwards switch to e.g. 'concierge@yourdomain.com'.
[email protected]

# --- Anti-abuse ---
# A 32+ character random secret used to HMAC-hash visitor IPs before they
# are stored in the audit log. Generate fresh on first deploy:
#
#   On Windows PowerShell:
#     [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#
#   On macOS / Linux:
#     openssl rand -base64 32
#
# Treat this like a password. Rotating it invalidates old audit hashes
# (you can no longer match an old hash to a current IP) but doesn't
# affect the system's operation.
IP_HASH_SECRET=replace_with_32+_char_random_string

# --- Redis (audit log) ---
# Set automatically by Vercel when you connect the Redis integration
# to the project. You should not need to add this manually.
KV_REDIS_URL=redis://...
